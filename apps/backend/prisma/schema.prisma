// Schema inicial do SIG-Mechanic - cobre o MVP do Roadmap (ver SIG-Mechanic.md)
// Convencao: nomes de tabela/coluna em snake_case via @@map/@map; camelCase no TS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------
// Autenticacao / RBAC
// ------------------------------

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  active       Boolean  @default(true)
  roleId       String   @map("role_id")
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs AuditLog[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")

  @@map("roles")
}

model Permission {
  id    String           @id @default(uuid())
  code  String           @unique // ex: clientes.criar, clientes.editar
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ------------------------------
// Clientes
// ------------------------------

model Client {
  id           String    @id @default(uuid())
  legacyCode   String?   @map("legacy_code") // rastreabilidade com clientes.dbf (NUMERO)
  type         ClientType @default(PF)
  name         String
  cpf          String?
  cnpj         String?
  rg           String?
  ie           String?
  birthDate    DateTime? @map("birth_date")
  phone        String?
  whatsapp     String?
  email        String?
  zipCode      String?   @map("zip_code")
  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  notes        String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  vehicles Vehicle[]
  orders   Order[]
  budgets  Budget[]
  receivables Receivable[]

  @@map("clients")
}

enum ClientType {
  PF
  PJ
}

// ------------------------------
// Veiculos
// ------------------------------

model VehicleBrand {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  models   VehicleModel[]
  vehicles Vehicle[]

  @@map("vehicle_brands")
}

model VehicleModel {
  id        String   @id @default(uuid())
  brandId   String   @map("brand_id")
  brand     VehicleBrand @relation(fields: [brandId], references: [id])
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  vehicles Vehicle[]

  @@unique([brandId, name])
  @@map("vehicle_models")
}

model Vehicle {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  client     Client   @relation(fields: [clientId], references: [id])
  brandId    String   @map("brand_id")
  brand      VehicleBrand @relation(fields: [brandId], references: [id])
  modelId    String   @map("model_id")
  model      VehicleModel @relation(fields: [modelId], references: [id])
  year       String?
  color      String?
  fuel       String?
  engine     String?
  plate      String
  chassis    String?
  renavam    String?
  currentKm  Int?     @map("current_km")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orders     Order[]
  budgets    Budget[]
  oilChanges OilChangeRecord[]

  @@map("vehicles")
}

// ------------------------------
// Controle de Troca de Oleo
// ------------------------------

// Historico de trocas de oleo por veiculo, independente da OS (pode ser
// registrado avulso ou vinculado a uma Ordem de Servico especifica).
model OilChangeRecord {
  id             String    @id @default(uuid())
  vehicleId      String    @map("vehicle_id")
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  orderId        String?   @map("order_id")
  order          Order?    @relation(fields: [orderId], references: [id])
  changeDate     DateTime  @map("change_date")
  currentKm      Int       @map("current_km")
  nextChangeKm   Int?      @map("next_change_km")
  nextChangeDate DateTime? @map("next_change_date")
  oilType        String?   @map("oil_type")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("oil_change_records")
}

// ------------------------------
// Mecanicos / Operadores
// ------------------------------

model Mechanic {
  id                String   @id @default(uuid())
  name              String
  phone             String?
  specialty         String?
  active            Boolean  @default(true)
  admissionDate     DateTime? @map("admission_date")
  commissionPercent Decimal? @map("commission_percent") @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  orderServices OrderService[]
  commissions   Commission[]

  @@map("mechanics")
}

model Operator {
  id        String   @id @default(uuid())
  name      String
  role      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("operators")
}

// ------------------------------
// Servicos (catalogo)
// ------------------------------

model Service {
  id          String   @id @default(uuid())
  name        String
  category    String?
  price       Decimal  @db.Decimal(10, 2)
  avgTimeMin  Int?     @map("avg_time_min")
  warrantyDays Int?    @map("warranty_days")
  description String?
  active      Boolean  @default(true)

  orderServices OrderService[]
  budgetItems   BudgetItem[]

  @@map("services")
}

// ------------------------------
// Ordem de Servico
// ------------------------------

model Order {
  id             String      @id @default(uuid())
  legacyNumber   String?     @map("legacy_number")
  clientId       String      @map("client_id")
  client         Client      @relation(fields: [clientId], references: [id])
  vehicleId      String      @map("vehicle_id")
  vehicle        Vehicle     @relation(fields: [vehicleId], references: [id])
  status         OrderStatus @default(OPEN)
  openedAt       DateTime    @default(now()) @map("opened_at")
  closedAt       DateTime?   @map("closed_at")
  partsTotal     Decimal     @default(0) @map("parts_total") @db.Decimal(10, 2)
  servicesTotal  Decimal     @default(0) @map("services_total") @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  orderServices OrderService[]
  orderItems    OrderItem[]
  budget        Budget?
  commissions   Commission[]
  oilChanges    OilChangeRecord[]

  @@map("orders")
}

enum OrderStatus {
  OPEN
  WAITING_PARTS
  IN_PROGRESS
  WAITING_CLIENT
  DONE
  CANCELLED
}

model OrderService {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId  String   @map("service_id")
  service    Service  @relation(fields: [serviceId], references: [id])
  mechanicId String?  @map("mechanic_id")
  mechanic   Mechanic? @relation(fields: [mechanicId], references: [id])
  price      Decimal  @db.Decimal(10, 2)
  commission Commission?

  @@map("order_services")
}

// Pecas lancadas na OS. NAO controla estoque (sem vinculo com inventario) -
// dados de produto/preco reais vem do SIV-NG; aqui e apenas o registro do
// item usado/vendido dentro da ordem de servico.
model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)

  @@map("order_items")
}

// ------------------------------
// Orcamentos
// ------------------------------

model Budget {
  id            String       @id @default(uuid())
  legacyNumber  String?      @map("legacy_number")
  clientId      String       @map("client_id")
  client        Client       @relation(fields: [clientId], references: [id])
  vehicleId     String?      @map("vehicle_id")
  vehicle       Vehicle?     @relation(fields: [vehicleId], references: [id])
  status        BudgetStatus @default(DRAFT)
  discount      Decimal      @default(0) @db.Decimal(10, 2)
  validUntil    DateTime?    @map("valid_until")
  notes         String?
  convertedOrderId String?   @unique @map("converted_order_id")
  convertedOrder    Order?   @relation(fields: [convertedOrderId], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  items BudgetItem[]

  @@map("budgets")
}

enum BudgetStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  CONVERTED
  EXPIRED
}

enum BudgetItemType {
  PART
  SERVICE
}

model BudgetItem {
  id          String         @id @default(uuid())
  budgetId    String         @map("budget_id")
  budget      Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  type        BudgetItemType
  serviceId   String?        @map("service_id")
  service     Service?       @relation(fields: [serviceId], references: [id])
  description String
  quantity    Int            @default(1)
  unitPrice   Decimal        @map("unit_price") @db.Decimal(10, 2)

  @@map("budget_items")
}

// ------------------------------
// Financeiro (Contas a Pagar / Receber)
// ------------------------------

model Payable {
  id           String        @id @default(uuid())
  description  String
  supplierName String?       @map("supplier_name")
  dueDate      DateTime      @map("due_date")
  amount       Decimal       @db.Decimal(10, 2)
  status       PayableStatus @default(OPEN)
  paidAt       DateTime?     @map("paid_at")
  paidAmount   Decimal?      @map("paid_amount") @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("payables")
}

enum PayableStatus {
  OPEN
  PAID
  CANCELLED
}

model Receivable {
  id             String           @id @default(uuid())
  description    String
  clientId       String?          @map("client_id")
  client         Client?          @relation(fields: [clientId], references: [id])
  dueDate        DateTime         @map("due_date")
  amount         Decimal          @db.Decimal(10, 2)
  status         ReceivableStatus @default(OPEN)
  receivedAt     DateTime?        @map("received_at")
  receivedAmount Decimal?         @map("received_amount") @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@map("receivables")
}

enum ReceivableStatus {
  OPEN
  RECEIVED
  CANCELLED
}

// ------------------------------
// Comissao (ledger)
// ------------------------------

// Gerado automaticamente quando uma Ordem de Servico e finalizada (status
// DONE), um registro por servico executado com mecanico atribuido. Permite
// controlar o pagamento da comissao separadamente da OS.
model Commission {
  id             String           @id @default(uuid())
  mechanicId     String           @map("mechanic_id")
  mechanic       Mechanic         @relation(fields: [mechanicId], references: [id])
  orderId        String           @map("order_id")
  order          Order            @relation(fields: [orderId], references: [id])
  orderServiceId String           @unique @map("order_service_id")
  orderService   OrderService     @relation(fields: [orderServiceId], references: [id])
  amount         Decimal          @db.Decimal(10, 2)
  status         CommissionStatus @default(PENDING)
  paidAt         DateTime?        @map("paid_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@map("commissions")
}

enum CommissionStatus {
  PENDING
  PAID
}

// ------------------------------
// Auditoria
// ------------------------------

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String // CREATE, UPDATE, DELETE, IMPORT_LEGACY
  entity    String // ex: Client, Order
  entityId  String?  @map("entity_id")
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
